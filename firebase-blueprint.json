{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data, excluding sensitive PII if possible. Main entry for RBAC.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "role", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product definition.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "isBestSeller": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "description", "price", "category", "stock", "isBestSeller", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order containing a snapshot of items, total amount, and fulfillment status.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingDetails": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "OrderItem": {
      "title": "Order Item",
      "description": "An item inside an order.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" }
      },
      "required": ["productId", "quantity", "price"]
    },
    "Review": {
      "title": "Product Review",
      "description": "Review for a product left by a user.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt", "updatedAt"]
    },
    "ContactMessage": {
      "title": "Contact Form Message",
      "description": "Messages from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "phone", "message", "createdAt"]
    },
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Global settings and content for the website",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "contactEmail": { "type": "string" },
        "aboutTitle": { "type": "string" },
        "aboutSubtitle": { "type": "string" },
        "aboutBody1": { "type": "string" },
        "aboutBody2": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "seoKeywords": { "type": "string" },
        "categories": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": { 
              "id": { "type": "string" }, 
              "name": { "type": "string" } 
            },
            "required": ["id", "name"]
          } 
        },
        "updatedAt": { "type": "number" }
      },
      "required": ["siteName", "heroTitle", "heroSubtitle", "contactEmail", "aboutTitle", "aboutSubtitle", "aboutBody1", "aboutBody2", "seoTitle", "seoDescription", "seoKeywords", "categories", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Trusted document indicating a user is an admin.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "Blog post or article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "content", "authorId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Contains basic user info and rules."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "General product catalog. Readable by all, writable by admins."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders placed by users. Readable by the user and admins, writable by user (create only initially) and admins."
    },
    "/orders/{orderId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/OrderItem" },
      "description": "Line items for specific order."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Product reviews."
    },
    "/contactMessages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "Contact messages created by site visitors. Writable by all (append only), readable by admins."
    },
    "admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Records mapping user UIDs to Admin role."
    },
    "/siteConfig/{configId}": {
      "schema": { "$ref": "#/entities/SiteConfig" },
      "description": "Global settings for the website. Readable by all, writable by admins."
    },
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Blog articles. Readable by all, writable by admins."
    }
  }
}
