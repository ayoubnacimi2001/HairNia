rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // --- Core Primitives & Macros ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        (request.auth.token.email == 'ayoubnacimi2001@gmail.com' && request.auth.token.email_verified == true)
      ); 
    }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validators --- //
    // Validation for User profile
    function isValidUser(data) {
      return data.keys().hasOnly(['email', 'role', 'createdAt', 'updatedAt', 'authProvider', 'name'])
        && data.keys().hasAll(['email', 'role', 'createdAt', 'updatedAt', 'authProvider'])
        && data.email is string && data.email.size() <= 200
        && data.role is string && (data.role == 'user' || data.role == 'admin')
        && data.authProvider is string && (data.authProvider == 'google' || data.authProvider == 'local')
        && (!('name' in data) || data.name is string && data.name.size() <= 200)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Validation for Product
    function isValidProduct(data) {
      return data.keys().hasOnly(['title', 'description', 'price', 'category', 'stock', 'imageUrl', 'isBestSeller', 'createdAt', 'updatedAt'])
        && data.keys().hasAll(['title', 'description', 'price', 'category', 'stock', 'isBestSeller', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 150
        && data.description is string && data.description.size() <= 5000
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() <= 100
        && data.stock is int && data.stock >= 0
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 3000000))
        && data.isBestSeller is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Validation for Order
    function isValidOrder(data) {
      return data.keys().hasOnly(['userId', 'totalAmount', 'status', 'createdAt', 'updatedAt'])
        && data.keys().hasAll(['userId', 'totalAmount', 'status', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.totalAmount is number && data.totalAmount >= 0
        && data.status is string && (data.status == 'pending' || data.status == 'processing' || data.status == 'shipped' || data.status == 'delivered' || data.status == 'cancelled')
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }
    
    // Validation for OrderItem
    function isValidOrderItem(data) {
      return data.keys().hasOnly(['productId', 'quantity', 'price'])
        && data.keys().hasAll(['productId', 'quantity', 'price'])
        && data.productId is string && data.productId.size() <= 128
        && data.quantity is int && data.quantity > 0
        && data.price is number && data.price >= 0;
    }

    // Validation for Review
    function isValidReview(data) {
      return data.keys().hasOnly(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt', 'updatedAt'])
        && data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt', 'updatedAt'])
        && data.productId is string && data.productId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 100
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Validation for ContactMessage
    function isValidContactMessage(data) {
      return data.keys().hasOnly(['name', 'email', 'phone', 'message', 'createdAt'])
        && data.keys().hasAll(['name', 'email', 'phone', 'message', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.message is string && data.message.size() <= 2000
        && data.createdAt is timestamp;
    }
    
    // Validation for SiteConfig
    function isValidSiteConfig(data) {
      return data.keys().hasOnly(['siteName', 'heroTitle', 'heroSubtitle', 'contactEmail', 'aboutTitle', 'aboutSubtitle', 'aboutBody1', 'aboutBody2', 'seoTitle', 'seoDescription', 'seoKeywords', 'categories', 'logoUrl', 'heroImageUrl', 'themePrimaryColor', 'updatedAt'])
        && data.keys().hasAll(['siteName', 'heroTitle', 'heroSubtitle', 'contactEmail', 'aboutTitle', 'aboutSubtitle', 'aboutBody1', 'aboutBody2', 'seoTitle', 'seoDescription', 'seoKeywords', 'categories', 'updatedAt'])
        && data.siteName is string && data.siteName.size() <= 100
        && data.heroTitle is string && data.heroTitle.size() <= 200
        && data.heroSubtitle is string && data.heroSubtitle.size() <= 600
        && data.contactEmail is string && data.contactEmail.size() <= 200
        && data.aboutTitle is string && data.aboutTitle.size() <= 200
        && data.aboutSubtitle is string && data.aboutSubtitle.size() <= 600
        && data.aboutBody1 is string && data.aboutBody1.size() <= 2000
        && data.aboutBody2 is string && data.aboutBody2.size() <= 2000
        && data.seoTitle is string && data.seoTitle.size() <= 200
        && data.seoDescription is string && data.seoDescription.size() <= 1000
        && data.seoKeywords is string && data.seoKeywords.size() <= 1000
        && data.categories is list && data.categories.size() <= 50
        && (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 3000000))
        && (!('heroImageUrl' in data) || (data.heroImageUrl is string && data.heroImageUrl.size() <= 3000000))
        && (!('themePrimaryColor' in data) || (data.themePrimaryColor is string && data.themePrimaryColor.size() <= 50))
        && data.updatedAt is timestamp;
    }

    // Validation for Article
    function isValidArticle(data) {
      return data.keys().hasOnly(['title', 'content', 'authorId', 'createdAt', 'updatedAt'])
        && data.keys().hasAll(['title', 'content', 'authorId', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000
        && data.authorId is string && data.authorId.size() <= 128
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Admin Record Validator
    function isValidAdmin(data) {
      return data.keys().hasOnly(['createdAt', 'email'])
        && data.keys().hasAll(['createdAt', 'email'])
        && data.createdAt is timestamp
        && data.email is string;
    }


    // --- Collections --- //

    // 1. Admins
    match /admins/{userId} {
      // Only readable by admins or self
      allow get: if isSignedIn() && isValidId(userId) && (isAdmin() || request.auth.uid == userId);
      allow list: if isAdmin();
      allow create, update: if isAdmin() && isValidAdmin(incoming());
      allow delete: if isAdmin();
    }

    // 2. Users
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (isAdmin() || request.auth.uid == userId);
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId
        && isValidUser(incoming())
        // Cannot self-assign admin unless actually an admin or the designated initial admin email
        && (incoming().role == 'user' || (incoming().role == 'admin' && isAdmin()))
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() && isValidId(userId) && (isAdmin() || request.auth.uid == userId)
        && isValidUser(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && (isAdmin() || incoming().role == existing().role)
        && (
           isAdmin() ||
           // Normal user can only update basic fields
           (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']))
        );
        
      allow delete: if isAdmin();
    }

    // 3. Products
    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
      
      allow create: if isAdmin() && isValidId(productId)
        && isValidProduct(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isAdmin() && isValidId(productId)
        && isValidProduct(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isAdmin() && isValidId(productId);
    }

    // 4. Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && isValidId(orderId) && (isAdmin() || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidId(orderId)
        && isValidOrder(incoming())
        && incoming().userId == request.auth.uid
        && incoming().status == 'pending' // Users can only create pending orders
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() && isValidId(orderId) && (isAdmin() || existing().userId == request.auth.uid)
        && isValidOrder(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          isAdmin() ||
          // User can only cancel their own order if it's pending
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && existing().status == 'pending' && incoming().status == 'cancelled')
        );
        
      allow delete: if false; // Orders should not be deleted, only cancelled
      
      // Order Items subcollection
      match /items/{itemId} {
        // Need to check parent order access
        function getOrderForRead() {
          return get(/databases/$(database)/documents/orders/$(orderId));
        }
        function getOrderForWrite() {
          // Always verify the order state AFTER the batch to prevent sneaking items into processing orders
          return getAfter(/databases/$(database)/documents/orders/$(orderId));
        }
        function isOrderOwnerForRead() {
          let order = getOrderForRead();
          return order != null && order.data.userId == request.auth.uid;
        }
        function isOrderOwnerForWrite() {
          let order = getOrderForWrite();
          return order != null && order.data.userId == request.auth.uid;
        }
        function isOrderPendingForWrite() {
          let order = getOrderForWrite();
          return order != null && order.data.status == 'pending';
        }
        function isProductValid(productId, price, quantity) {
          let product = get(/databases/$(database)/documents/products/$(productId));
          return product != null 
            && product.data.price == price 
            && product.data.stock >= quantity;
        }
        
        allow get: if isSignedIn() && isValidId(itemId) && (isAdmin() || isOrderOwnerForRead());
        allow list: if isSignedIn() && (isAdmin() || isOrderOwnerForRead());
        
        allow create: if isSignedIn() && isValidId(itemId)
          // Ideally existing() on the parent isn't working if we batch create, wait, in a batch you can use getAfter() but let's just allow if user is matching the payload context
          && isValidOrderItem(incoming())
          && (isAdmin() || (isOrderOwnerForWrite() && isOrderPendingForWrite() && isProductValid(incoming().productId, incoming().price, incoming().quantity))); 
          
        allow update: if isSignedIn() && isValidId(itemId)
          && isValidOrderItem(incoming())
          && (
            isAdmin() || 
            (isOrderOwnerForWrite() && isOrderPendingForWrite() 
              && incoming().productId == existing().productId 
              && isProductValid(incoming().productId, incoming().price, incoming().quantity))
          );
          
        allow delete: if isSignedIn() && isValidId(itemId) && (isAdmin() || (isOrderOwnerForWrite() && isOrderPendingForWrite()));
      }
    }

    // 5. Reviews
    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId);
      allow list: if true; // Public can see reviews
      
      allow create: if isSignedIn() && isValidId(reviewId)
        && isValidReview(incoming())
        && incoming().userId == request.auth.uid
        && exists(/databases/$(database)/documents/products/$(incoming().productId)) // Prevent orphaned reviews
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() && isValidId(reviewId) && (isAdmin() || existing().userId == request.auth.uid)
        && isValidReview(incoming())
        && incoming().userId == existing().userId
        && incoming().productId == existing().productId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          isAdmin() ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt']))
        );
        
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // 6. ContactMessages
    match /contactMessages/{messageId} {
      // Anyone can submit a message
      allow create: if isValidId(messageId)
        && isValidContactMessage(incoming())
        && incoming().createdAt == request.time;
        
      allow get, list, update, delete: if isAdmin();
    }

    // 7. SiteConfig
    match /siteConfig/{configId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidId(configId) && isValidSiteConfig(incoming()) && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(configId) && isValidSiteConfig(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    // 8. Articles
    match /articles/{articleId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidId(articleId) && isValidArticle(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(articleId) && isValidArticle(incoming()) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(articleId);
    }
  }
}
